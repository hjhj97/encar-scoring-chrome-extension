{
  "manifest_version": 3,
  "name": "엔카 중고차 품질 점수",
  "version": "1.0.0",
  "description": "엔카 차량 리스트에서 각 중고차의 품질을 자동으로 점수화하여 표시합니다.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://car.encar.com/*",
    "https://fem.encar.com/*",
    "https://api.encar.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://car.encar.com/list/*"],
      "js": ["constants.js", "scoring.js", "detail-parser.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
